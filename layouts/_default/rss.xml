{{ define "main" }}
<!-- Main Content -->
<main class="main-content">
  <section class="section">
    <div dir="rtl" class="container">

      {{ $allPosts := slice }}
      {{ range .Site.Data.legal_sites.sites }}
          {{ $sourceName := .name }}
          {{ with resources.GetRemote .url }}
              {{ with . | transform.Unmarshal }}
                  {{ range first 15 .channel.item }}
                      {{ $allPosts = $allPosts | append (dict 
                          "title" .title 
                          "link" .link 
                          "date" .pubDate 
                          "source" $sourceName 
                          "desc" (.description | plainify | truncate 120)) }}
                  {{ end }}
              {{ end }}
          {{ end }}
      {{ end }}

      <div style="margin: auto; padding-right: 10%; padding-left: 5%">
        <div dir="rtl" class="row gap-y">

          {{/* مرتب‌سازی از جدید به قدیم */}}
          {{ range (sort $allPosts "date" "desc") }}
          <div class="col-md-6 text-right news">

            {{/* ۱. تیتر */}}
            <h6 class="mb-1 font-weight-600">
              <a href="{{ .link }}" target="_blank">{{ .title }}</a>
            </h6>

            {{/* ۲. توضیح */}}
            <p class="text-light mb-1">{{ .desc }}</p>

            {{/* ۳. منبع و ۴. تاریخ */}}
            <div class="post-meta" style="color: #999; font-size: 0.85em;">
              <span class="post-source">{{ .source }}</span>
              <span class="post-meta-sep"> | </span>
              <span class="card-date" data-utc="{{ .date }}">در حال بارگذاری...</span>
            </div>

          </div>
          {{ end }}

        </div>
      </div>

      {{/* صفحه‌بندی */}}
      <nav>
        <ul class="pagination justify-content-center mt-5">
          <li><button id="prev-btn" onclick="changePage(-1)">قبلی</button></li>
          <li><span id="page-num">صفحه ۱</span></li>
          <li><button id="next-btn" onclick="changePage(1)">بعدی</button></li>
        </ul>
      </nav>

    </div>
  </section>
</main>


<script>
  const sites = {{ .Site.Data.legal_sites.sites | jsonify }};
  let allPosts = [];
  const cardsPerPage = 14;
  let currentPage = 1;

  async function fetchRSS() {
    for (const site of sites) {
      try {
        const response = await fetch(site.url);
        const text = await response.text();
        const parser = new DOMParser();
        const xml = parser.parseFromString(text, 'application/xml');
        
        const items = xml.querySelectorAll('item');
        items.forEach((item, i) => {
          if (i < 15) {
            allPosts.push({
              title: item.querySelector('title')?.textContent || '—',
              link: item.querySelector('link')?.textContent || '#',
              date: item.querySelector('pubDate')?.textContent || '',
              source: site.name,
              desc: (item.querySelector('description')?.textContent || '').substring(0, 120)
            });
          }
        });
      } catch (e) {
        console.error(`خطا در دریافت ${site.name}:`, e);
      }
    }

    allPosts.sort((a, b) => new Date(b.date) - new Date(a.date));
    renderPosts();
  }

  function convertToJalali(dateStr) {
    const date = new Date(dateStr);
    if (isNaN(date)) return '—';
    return new Intl.DateTimeFormat('fa-IR', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    }).format(date);
  }

  function renderPosts() {
    const container = document.getElementById('posts-container');
    container.innerHTML = '';

    const start = (currentPage - 1) * cardsPerPage;
    const end = start + cardsPerPage
</script>

{{ end }}

