{{- $items := slice -}}
{{- range $slug, $law := .Site.Data.laws -}}
  {{- range $law.articles -}}
    {{- $items = $items | append (dict
        "law_slug" $slug
        "law_title" $law.title
        "number" .number
        "text" .text
        "url" (printf "/laws/%s/#madeh-%d" $slug .number)
      ) -}}
  {{- end -}}
{{- end -}}
{{- $items | jsonify -}}
